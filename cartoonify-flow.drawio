<mxfile host="app.diagrams.net" agent="Claude">
  <diagram id="cartoonify-flow" name="How to Cartoonify an Image">
    <mxGraphModel grid="1" page="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="950" pageHeight="1800" math="0" shadow="1">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=4;" value="" vertex="1">
          <mxGeometry height="130" width="750" x="75" y="82" as="geometry" />
        </mxCell>
        <mxCell id="s1n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="①" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="97" as="geometry" />
        </mxCell>
        <mxCell id="s1t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Sign In with Identity Platform&lt;/b&gt;&lt;br&gt;Open the app in the browser (GCS static URL) and enter your email and password — or create a new account.&lt;br&gt;&lt;b&gt;Identity Platform&lt;/b&gt; (Firebase Auth) validates credentials and returns a &lt;b&gt;Firebase ID token&lt;/b&gt; (JWT, 1-hour expiry).&lt;br&gt;The &lt;b&gt;Firebase JS SDK&lt;/b&gt; caches the token and auto-refreshes it via &lt;tt&gt;getIdToken()&lt;/tt&gt; before every API call.&lt;br&gt;The UI unlocks and the history gallery loads." vertex="1">
          <mxGeometry height="115" width="657" x="158" y="92" as="geometry" />
        </mxCell>
        <mxCell id="a12" edge="1" parent="1" source="s1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=4;" value="" vertex="1">
          <mxGeometry height="120" width="750" x="75" y="242" as="geometry" />
        </mxCell>
        <mxCell id="s2n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="②" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="257" as="geometry" />
        </mxCell>
        <mxCell id="s2t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Select &amp;amp; Validate Image&lt;/b&gt;&lt;br&gt;Use the file picker to select a photo. The browser validates immediately — no server round-trip required.&lt;br&gt;File type must be &lt;b&gt;JPEG, PNG, or WebP&lt;/b&gt;; file size must be &lt;b&gt;5 MB or less&lt;/b&gt;.&lt;br&gt;The &lt;b&gt;Cartoonify&lt;/b&gt; button stays disabled until a valid file is chosen." vertex="1">
          <mxGeometry height="105" width="657" x="158" y="250" as="geometry" />
        </mxCell>
        <mxCell id="a23" edge="1" parent="1" source="s2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=4;" value="" vertex="1">
          <mxGeometry height="135" width="750" x="75" y="392" as="geometry" />
        </mxCell>
        <mxCell id="s3n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d6b656;strokeColor=#d6b656;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="③" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="408" as="geometry" />
        </mxCell>
        <mxCell id="s3t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Request a V4 Signed Upload URL&lt;/b&gt;&lt;br&gt;&lt;b&gt;POST /upload-url&lt;/b&gt; with &lt;tt&gt;Authorization: Bearer &amp;lt;JWT&amp;gt;&lt;/tt&gt; and &lt;tt&gt;{ content_type }&lt;/tt&gt;. &lt;b&gt;API Gateway&lt;/b&gt; validates the JWT&lt;br&gt;signature against the &lt;b&gt;Identity Platform JWKS&lt;/b&gt; before invoking any Cloud Function — unauthenticated requests are rejected at the edge.&lt;br&gt;The &lt;b&gt;cartoonify_api function&lt;/b&gt; generates a time-sortable &lt;b&gt;job_id&lt;/b&gt; and calls GCS &lt;tt&gt;generate_signed_url&lt;/tt&gt; (V4, PUT method),&lt;br&gt;returning a signed URL valid for &lt;b&gt;300 seconds&lt;/b&gt; scoped to the owner and job ID." vertex="1">
          <mxGeometry height="120" width="657" x="158" y="400" as="geometry" />
        </mxCell>
        <mxCell id="a34" edge="1" parent="1" source="s3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=4;" value="" vertex="1">
          <mxGeometry height="115" width="750" x="75" y="557" as="geometry" />
        </mxCell>
        <mxCell id="s4n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#82b366;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="④" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="572" as="geometry" />
        </mxCell>
        <mxCell id="s4t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Upload Image Directly to GCS&lt;/b&gt;&lt;br&gt;The browser PUTs the image file &lt;b&gt;directly to GCS&lt;/b&gt; using the signed URL — bypassing Cloud Functions and API Gateway entirely.&lt;br&gt;Image data never touches the function network path. The &lt;tt&gt;Content-Type&lt;/tt&gt; header must match the signed URL exactly.&lt;br&gt;GCS stores the file at &lt;b&gt;originals/&amp;lt;owner&amp;gt;/&amp;lt;job_id&amp;gt;.&amp;lt;ext&amp;gt;&lt;/b&gt; in the private media bucket." vertex="1">
          <mxGeometry height="100" width="657" x="158" y="565" as="geometry" />
        </mxCell>
        <mxCell id="a45" edge="1" parent="1" source="s4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=4;" value="" vertex="1">
          <mxGeometry height="155" width="750" x="75" y="702" as="geometry" />
        </mxCell>
        <mxCell id="s5n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d6b656;strokeColor=#d6b656;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑤" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="718" as="geometry" />
        </mxCell>
        <mxCell id="s5t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Select Style &amp;amp; Submit the Cartoon Job&lt;/b&gt;&lt;br&gt;Pick a style: &lt;b&gt;Pixar 3D · Simpsons · Anime · Comic Book · Watercolor · Pencil Sketch&lt;/b&gt;.&lt;br&gt;Optionally type extra instructions (500 chars max). Click &lt;b&gt;Cartoonify&lt;/b&gt;.&lt;br&gt;&lt;b&gt;POST /generate&lt;/b&gt; sends &lt;tt&gt;{ job_id, key, style, prompt_extra }&lt;/tt&gt;. The &lt;b&gt;cartoonify_api function&lt;/b&gt; validates&lt;br&gt;the style, calls &lt;tt&gt;blob.reload()&lt;/tt&gt; to confirm the upload exists, queries Firestore to enforce the&lt;br&gt;&lt;b&gt;daily quota&lt;/b&gt; (max 10 cartoons per UTC day), writes &lt;tt&gt;status=submitted&lt;/tt&gt; to Firestore, then publishes to &lt;b&gt;Pub/Sub&lt;/b&gt;. Returns &lt;b&gt;202 Accepted&lt;/b&gt;." vertex="1">
          <mxGeometry height="140" width="657" x="158" y="710" as="geometry" />
        </mxCell>
        <mxCell id="a56" edge="1" parent="1" source="s5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=4;" value="" vertex="1">
          <mxGeometry height="140" width="750" x="75" y="887" as="geometry" />
        </mxCell>
        <mxCell id="s6n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d79b00;strokeColor=#d79b00;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑥" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="903" as="geometry" />
        </mxCell>
        <mxCell id="s6t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Pub/Sub Triggers the Worker Function&lt;/b&gt;&lt;br&gt;Pub/Sub delivers the job message to the &lt;b&gt;cartoonify-worker Cloud Function&lt;/b&gt; (Python 3.11, 2nd Gen)&lt;br&gt;via an &lt;b&gt;Eventarc&lt;/b&gt; trigger on the &lt;tt&gt;cartoonify-jobs&lt;/tt&gt; topic. The function has &lt;b&gt;512 MB&lt;/b&gt; memory and a &lt;b&gt;300 s&lt;/b&gt; timeout.&lt;br&gt;The subscription ack deadline is 300 s — the message stays hidden while the worker runs.&lt;br&gt;The worker marks &lt;tt&gt;status=processing&lt;/tt&gt; in Firestore, downloads the original from GCS, then runs &lt;b&gt;Pillow&lt;/b&gt;:&lt;br&gt;EXIF strip → RGB convert → center-square crop → resize to &lt;b&gt;1024 x 1024 px&lt;/b&gt; → encode as PNG for Vertex AI." vertex="1">
          <mxGeometry height="125" width="657" x="158" y="895" as="geometry" />
        </mxCell>
        <mxCell id="a67" edge="1" parent="1" source="s6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=4;" value="" vertex="1">
          <mxGeometry height="150" width="750" x="75" y="1057" as="geometry" />
        </mxCell>
        <mxCell id="s7n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#9673a6;strokeColor=#9673a6;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑦" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="1073" as="geometry" />
        </mxCell>
        <mxCell id="s7t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Vertex AI Imagen Generates the Cartoon&lt;/b&gt;&lt;br&gt;The worker calls &lt;b&gt;Vertex AI Imagen&lt;/b&gt; using &lt;tt&gt;imagen-3.0-capability-001&lt;/tt&gt; via the Python SDK&lt;br&gt;&lt;tt&gt;ImageGenerationModel.edit_image()&lt;/tt&gt; with a &lt;b&gt;SubjectReferenceImage&lt;/b&gt; (&lt;tt&gt;REFERENCE_TYPE_SUBJECT&lt;/tt&gt;, &lt;tt&gt;subject_type=person&lt;/tt&gt;).&lt;br&gt;This preserves the person&amp;apos;s likeness through the style transformation.&lt;br&gt;The request includes the &lt;b&gt;normalized image&lt;/b&gt; and a &lt;b&gt;style prompt&lt;/b&gt; — e.g. &lt;i&gt;Pixar 3D animated portrait,&lt;br&gt;subsurface skin shading, warm rim lighting, large expressive eyes&lt;/i&gt; — plus any extra user instructions.&lt;br&gt;The model returns the generated cartoon as &lt;b&gt;PNG bytes&lt;/b&gt;. The Imagen model ID is fully parameterized via &lt;tt&gt;imagen-config.sh&lt;/tt&gt;." vertex="1">
          <mxGeometry height="135" width="657" x="158" y="1065" as="geometry" />
        </mxCell>
        <mxCell id="a78" edge="1" parent="1" source="s7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=4;" value="" vertex="1">
          <mxGeometry height="120" width="750" x="75" y="1237" as="geometry" />
        </mxCell>
        <mxCell id="s8n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#82b366;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑧" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="1253" as="geometry" />
        </mxCell>
        <mxCell id="s8t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Store Cartoon &amp;amp; Update Job Status&lt;/b&gt;&lt;br&gt;The worker uploads the generated cartoon PNG to GCS at &lt;b&gt;cartoons/&amp;lt;owner&amp;gt;/&amp;lt;job_id&amp;gt;.png&lt;/b&gt; in the private media bucket,&lt;br&gt;then updates the Firestore job document: &lt;tt&gt;status=complete&lt;/tt&gt;, &lt;tt&gt;cartoon_key&lt;/tt&gt;, and &lt;tt&gt;completed_at&lt;/tt&gt;.&lt;br&gt;Both files are subject to a &lt;b&gt;7-day GCS lifecycle rule&lt;/b&gt; and matching &lt;b&gt;Firestore TTL&lt;/b&gt; field.&lt;br&gt;On any exception the worker marks &lt;tt&gt;status=error&lt;/tt&gt; and swallows the exception — Pub/Sub does not redrive (dead-letter handles failures)." vertex="1">
          <mxGeometry height="105" width="657" x="158" y="1245" as="geometry" />
        </mxCell>
        <mxCell id="a89" edge="1" parent="1" source="s8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=4;" value="" vertex="1">
          <mxGeometry height="125" width="750" x="75" y="1387" as="geometry" />
        </mxCell>
        <mxCell id="s9n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑨" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="1403" as="geometry" />
        </mxCell>
        <mxCell id="s9t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Poll for Result &amp;amp; Display Cartoon&lt;/b&gt;&lt;br&gt;While the job runs, the browser calls &lt;b&gt;GET /result/{job_id}&lt;/b&gt; every &lt;b&gt;2 seconds&lt;/b&gt; (up to 90 attempts, ~3 minutes).&lt;br&gt;Each response includes the current &lt;tt&gt;status&lt;/tt&gt; field. When &lt;tt&gt;status=complete&lt;/tt&gt;, the API returns&lt;br&gt;&lt;b&gt;V4 signed GET URLs&lt;/b&gt; (4-hour expiry) for both the original upload and the generated cartoon.&lt;br&gt;The cartoon renders in the current-job panel. The history gallery reloads and auto-refreshes every 10 s while any tile is pending." vertex="1">
          <mxGeometry height="110" width="657" x="158" y="1395" as="geometry" />
        </mxCell>
        <mxCell id="a910" edge="1" parent="1" source="s9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="s10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=4;" value="" vertex="1">
          <mxGeometry height="120" width="750" x="75" y="1542" as="geometry" />
        </mxCell>
        <mxCell id="s10n" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontSize=26;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" value="⑩" vertex="1">
          <mxGeometry height="56" width="56" x="90" y="1558" as="geometry" />
        </mxCell>
        <mxCell id="s10t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" value="&lt;b&gt;Browse History, Download &amp;amp; Delete&lt;/b&gt;&lt;br&gt;&lt;b&gt;GET /history&lt;/b&gt; returns the last &lt;b&gt;50 cartoons&lt;/b&gt; for the authenticated user, newest first,&lt;br&gt;each with V4 signed download URLs valid for 4 hours. The gallery renders as a responsive tile grid&lt;br&gt;showing both the original photo and generated cartoon side by side.&lt;br&gt;Click &lt;b&gt;Download&lt;/b&gt; to save the PNG. Click &lt;b&gt;Delete&lt;/b&gt; to call &lt;b&gt;DELETE /history/{job_id}&lt;/b&gt; — which removes&lt;br&gt;the original, the cartoon, and the Firestore document. Items expire automatically after &lt;b&gt;7 days&lt;/b&gt;." vertex="1">
          <mxGeometry height="105" width="657" x="158" y="1550" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
