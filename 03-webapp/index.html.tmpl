<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0"/>
  <meta http-equiv="Pragma" content="no-cache"/>
  <meta http-equiv="Expires" content="0"/>
  <title>Cartoonify</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <style>
    body {
      margin: 0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
      background: #0f172a;
      color: #e5e7eb;
    }

    header {
      padding: 16px;
      background: #020617;
      border-bottom: 1px solid #1e293b;
    }

    h1 { margin: 0; font-size: 18px; }

    main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 16px;
      display: grid;
      grid-template-columns: 360px 1fr;
      gap: 16px;
    }

    @media (max-width: 900px) { main { grid-template-columns: 1fr; } }

    section {
      background: #020617;
      border: 1px solid #1e293b;
      border-radius: 8px;
      padding: 14px;
    }

    section h2 { margin: 0 0 10px 0; font-size: 14px; color: #cbd5e1; }

    button {
      padding: 8px 14px;
      border-radius: 4px;
      border: none;
      cursor: pointer;
      background: #2563eb;
      color: white;
      font-size: 13px;
    }
    button:disabled { opacity: 0.5; cursor: not-allowed; }
    button.secondary { background: #475569; }
    button.delete    { background: #dc2626; }

    input, select, textarea {
      box-sizing: border-box;
      width: 100%;
      padding: 8px;
      margin-bottom: 10px;
      border-radius: 4px;
      border: 1px solid #1e293b;
      background: #020617;
      color: #e5e7eb;
      font-size: 13px;
    }

    label { font-size: 12px; color: #94a3b8; display: block; margin-bottom: 4px; }

    .status {
      margin-top: 10px;
      font-size: 12px;
      color: #94a3b8;
      white-space: pre-wrap;
    }

    .current-job {
      margin-top: 14px;
      padding: 12px;
      border: 1px dashed #334155;
      border-radius: 6px;
    }
    .current-job img {
      width: 120px;
      height: 120px;
      object-fit: cover;
      border-radius: 4px;
      display: block;
      margin-top: 8px;
    }

    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 12px;
    }

    .tile {
      border: 1px solid #1e293b;
      border-radius: 6px;
      overflow: hidden;
      background: #0b1220;
    }
    .tile-images {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: #1e293b;
    }
    .tile-image-wrap { position: relative; background: #020617; }
    .tile-image-wrap img {
      width: 100%;
      aspect-ratio: 1 / 1;
      object-fit: cover;
      display: block;
    }
    .tile-image-wrap .img-label {
      position: absolute;
      bottom: 5px; left: 5px;
      background: rgba(0,0,0,0.62);
      color: #e5e7eb;
      font-size: 10px;
      letter-spacing: 0.4px;
      padding: 2px 6px;
      border-radius: 3px;
    }
    .tile .meta {
      padding: 8px 10px;
      font-size: 12px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
    }
    .tile .meta .style-tag  { color: #94a3b8; }
    .tile .meta .status-tag { text-transform: uppercase; font-size: 10px; letter-spacing: 0.5px; }
    .tile .meta .status-tag.complete   { color: #34d399; }
    .tile .meta .status-tag.processing { color: #fbbf24; }
    .tile .meta .status-tag.submitted  { color: #60a5fa; }
    .tile .meta .status-tag.error      { color: #f87171; }

    /* ── Login panel ── */
    #loginPanel {
      max-width: 360px;
      margin: 60px auto;
      background: #020617;
      border: 1px solid #1e293b;
      border-radius: 10px;
      padding: 24px;
    }
    #loginPanel h2 { margin: 0 0 16px; font-size: 16px; }
    #loginPanel .row { display: flex; gap: 8px; margin-top: 4px; }
    #loginStatus { color: #f87171; font-size: 12px; margin-top: 8px; }

    /* ── Busy overlay ── */
    .busy-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.35);
      backdrop-filter: blur(2px);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 2000;
    }
    .busy-overlay.active { display: flex; cursor: wait; }
    .busy-box {
      padding: 16px 18px;
      background: #020617;
      border: 1px solid #1e293b;
      border-radius: 10px;
      font-size: 13px;
      color: #e5e7eb;
    }
  </style>
</head>

<body>

<!-- ── Login ── -->
<div id="loginPanel">
  <h2>Sign in to Cartoonify</h2>
  <label>Email</label>
  <input id="loginEmail"    type="email"    placeholder="you@example.com" />
  <label>Password</label>
  <input id="loginPassword" type="password" placeholder="Password" />
  <div class="row">
    <button id="btnSignIn">Sign in</button>
    <button id="btnCreateAccount" class="secondary">Create account</button>
  </div>
  <div style="margin-top:8px;">
    <a id="btnForgotPassword" href="#" style="font-size:12px; color:#94a3b8;">Forgot password?</a>
  </div>
  <div id="loginStatus"></div>
</div>

<!-- ── App ── -->
<div id="cartoonifyApp" style="display:none">

<header>
  <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; max-width:1200px; margin:0 auto;">
    <h1>Cartoonify</h1>
    <div style="display:flex; align-items:center; gap:10px;">
      <span id="userEmail" style="font-size:12px; color:#94a3b8;"></span>
      <button id="btnSignOut" class="secondary">Sign out</button>
    </div>
  </div>
</header>

<main>

  <!-- Submit panel -->
  <section>
    <h2>Create a cartoon</h2>

    <label for="fileInput">Image (JPEG / PNG / WebP, max 5 MB)</label>
    <input id="fileInput" type="file" accept="image/jpeg,image/png,image/webp" />

    <label for="styleSelect">Style</label>
    <select id="styleSelect">
      <option value="pixar_3d">Pixar 3D</option>
      <option value="simpsons">Simpsons</option>
      <option value="anime">Anime</option>
      <option value="comic_book">Comic Book</option>
      <option value="watercolor">Watercolor</option>
      <option value="pencil_sketch">Pencil Sketch</option>
    </select>

    <label for="promptExtra">Extra instructions (optional, max 500 chars)</label>
    <textarea id="promptExtra" maxlength="500" rows="3"
              placeholder="e.g. wearing a red hat, smiling, standing in a forest"></textarea>

    <button id="btnSubmit" disabled>Cartoonify</button>

    <div id="submitStatus" class="status"></div>

    <div id="currentJob" class="current-job" style="display:none;">
      <div id="currentJobStatus" class="status"></div>
      <img id="currentJobImg" style="display:none;" alt="cartoon result" />
    </div>
  </section>

  <!-- Gallery -->
  <section>
    <div style="display:flex; align-items:center; justify-content:space-between;">
      <h2 style="margin:0;">History</h2>
      <button id="btnRefresh" class="secondary">Refresh</button>
    </div>
    <div id="gallery" class="gallery" style="margin-top:12px;"></div>
    <div id="galleryStatus" class="status"></div>
  </section>

</main>

</div><!-- /cartoonifyApp -->

<div id="busyOverlay" class="busy-overlay"><div class="busy-box">Working…</div></div>

<script type="module">
import { initializeApp }
  from 'https://www.gstatic.com/firebasejs/10.14.1/firebase-app.js';
import {
  getAuth,
  onAuthStateChanged,
  signInWithEmailAndPassword,
  createUserWithEmailAndPassword,
  sendPasswordResetEmail,
  signOut,
} from 'https://www.gstatic.com/firebasejs/10.14.1/firebase-auth.js';

// =========================================================================
// Config (generated at deploy time, loaded at runtime)
// =========================================================================
const config = await fetch('./config.json', { cache: 'no-store' }).then(r => r.json());

const app  = initializeApp({
  apiKey:    config.apiKey,
  authDomain: config.authDomain,
  projectId:  config.projectId,
});
const auth = getAuth(app);

const API_BASE = config.apiBaseUrl;
const MAX_BYTES = 5 * 1024 * 1024;
const MAX_DIM   = 2048;
const POLL_MS            = 2000;
const POLL_MAX           = 90;    // ~3 minutes
const GALLERY_REFRESH_MS = 10000;

let pollTimer    = null;
let galleryTimer = null;

// =========================================================================
// Elements
// =========================================================================
const loginPanel     = document.getElementById('loginPanel');
const cartoonifyApp  = document.getElementById('cartoonifyApp');
const elLoginEmail   = document.getElementById('loginEmail');
const elLoginPwd     = document.getElementById('loginPassword');
const elLoginStatus  = document.getElementById('loginStatus');
const elUserEmail    = document.getElementById('userEmail');
const btnSignOut     = document.getElementById('btnSignOut');
const btnSubmit      = document.getElementById('btnSubmit');
const fileInput      = document.getElementById('fileInput');
const styleSelect    = document.getElementById('styleSelect');
const promptExtra    = document.getElementById('promptExtra');
const busyOverlay    = document.getElementById('busyOverlay');

// =========================================================================
// Auth state
// =========================================================================
onAuthStateChanged(auth, user => {
  if (user) {
    loginPanel.style.display    = 'none';
    cartoonifyApp.style.display = 'block';
    elUserEmail.textContent     = user.email;
    updateSubmitButton();
    loadHistory();
  } else {
    loginPanel.style.display    = '';
    cartoonifyApp.style.display = 'none';
    elUserEmail.textContent     = '';
    stopGalleryRefresh();
  }
});

async function signIn() {
  elLoginStatus.textContent = '';
  const email = elLoginEmail.value.trim();
  const pwd   = elLoginPwd.value;
  if (!email || !pwd) { elLoginStatus.textContent = 'Email and password required'; return; }
  setBusy(true);
  try {
    await signInWithEmailAndPassword(auth, email, pwd);
  } catch(e) {
    elLoginStatus.textContent = e.message;
  } finally {
    setBusy(false);
  }
}

async function createAccount() {
  elLoginStatus.textContent = '';
  const email = elLoginEmail.value.trim();
  const pwd   = elLoginPwd.value;
  if (!email || !pwd) { elLoginStatus.textContent = 'Email and password required'; return; }
  setBusy(true);
  try {
    await createUserWithEmailAndPassword(auth, email, pwd);
  } catch(e) {
    elLoginStatus.textContent = e.message;
  } finally {
    setBusy(false);
  }
}

async function forgotPassword() {
  elLoginStatus.textContent = '';
  const email = elLoginEmail.value.trim();
  if (!email) { elLoginStatus.textContent = 'Enter your email address first'; return; }
  setBusy(true);
  try {
    await sendPasswordResetEmail(auth, email);
    elLoginStatus.style.color = '#4ade80';
    elLoginStatus.textContent = 'Password reset email sent';
  } catch(e) {
    elLoginStatus.style.color = '';
    elLoginStatus.textContent = e.message;
  } finally {
    setBusy(false);
  }
}

document.getElementById('btnSignIn').addEventListener('click', signIn);
document.getElementById('btnCreateAccount').addEventListener('click', createAccount);
document.getElementById('btnForgotPassword').addEventListener('click', e => { e.preventDefault(); forgotPassword(); });
elLoginPwd.addEventListener('keydown', e => { if (e.key === 'Enter') signIn(); });
btnSignOut.addEventListener('click', () => signOut(auth));

// =========================================================================
// API helper — always attaches a fresh Firebase ID token
// =========================================================================
async function api(path, method = 'GET', body) {
  const user = auth.currentUser;
  if (!user) throw new Error('Not signed in');
  // getIdToken() auto-refreshes when the token is near expiry
  const token = await user.getIdToken();
  const res = await fetch(API_BASE + path, {
    method,
    headers: {
      'Content-Type':  'application/json',
      'Authorization': 'Bearer ' + token,
    },
    body: body ? JSON.stringify(body) : undefined,
  });
  const text = await res.text();
  const data = text ? JSON.parse(text) : null;
  if (!res.ok) throw new Error((data && data.error) || res.status);
  return data;
}

function setBusy(on) { busyOverlay.classList.toggle('active', on); }
function setSubmitStatus(msg) { document.getElementById('submitStatus').textContent = msg || ''; }
function setGalleryStatus(msg) { document.getElementById('galleryStatus').textContent = msg || ''; }
function updateSubmitButton() {
  btnSubmit.disabled = !auth.currentUser || !fileInput.files[0];
}
fileInput.addEventListener('change', updateSubmitButton);

// =========================================================================
// Client-side file validation
// =========================================================================
function validateFile(file) {
  return new Promise((resolve, reject) => {
    if (!file) return reject(new Error('Please choose an image'));
    if (!['image/jpeg', 'image/png', 'image/webp'].includes(file.type))
      return reject(new Error('Unsupported type — use JPEG, PNG, or WebP'));
    if (file.size > MAX_BYTES)
      return reject(new Error('File exceeds 5 MB limit'));
    const img = new Image();
    const url = URL.createObjectURL(file);
    img.onload = () => {
      URL.revokeObjectURL(url);
      if (img.width > MAX_DIM || img.height > MAX_DIM)
        reject(new Error('Image dimensions exceed ' + MAX_DIM + ' px'));
      else resolve();
    };
    img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('Could not read image')); };
    img.src = url;
  });
}

// =========================================================================
// Submit flow
// =========================================================================
async function submitJob() {
  const file  = fileInput.files[0];
  const style = styleSelect.value;
  const extra = (promptExtra.value || '').trim();

  try { await validateFile(file); }
  catch (e) { setSubmitStatus(e.message); return; }

  setBusy(true);
  setSubmitStatus('Requesting upload URL…');
  try {
    // 1. Get signed PUT URL
    const presign = await api('/upload-url', 'POST', { content_type: file.type });

    // 2. Upload directly to GCS via signed PUT URL
    setSubmitStatus('Uploading image…');
    const upRes = await fetch(presign.upload_url, {
      method:  'PUT',
      headers: { 'Content-Type': file.type },
      body:    file,
    });
    if (!upRes.ok) {
      const txt = await upRes.text();
      throw new Error('Upload failed: ' + upRes.status + ' ' + txt);
    }

    // 3. Submit job
    setSubmitStatus('Queuing job…');
    const sub = await api('/generate', 'POST', {
      job_id:       presign.job_id,
      key:          presign.key,
      style,
      prompt_extra: extra,
    });

    setSubmitStatus('Submitted — waiting for result…');
    showCurrentJob(sub.job_id, 'submitted', null);
    pollResult(sub.job_id);

  } catch (e) {
    setSubmitStatus('Error: ' + e.message);
  } finally {
    setBusy(false);
  }
}

btnSubmit.addEventListener('click', submitJob);

function showCurrentJob(job_id, status, url) {
  const cj  = document.getElementById('currentJob');
  const cjs = document.getElementById('currentJobStatus');
  const cji = document.getElementById('currentJobImg');
  cj.style.display = 'block';
  cjs.textContent  = 'Job ' + job_id + ' → ' + status;
  if (url) { cji.src = url; cji.style.display = 'block'; }
  else     { cji.style.display = 'none'; }
}

function stopPoll() { if (pollTimer) { clearTimeout(pollTimer); pollTimer = null; } }

function pollResult(job_id, attempt = 0) {
  stopPoll();
  if (attempt >= POLL_MAX) { showCurrentJob(job_id, 'timed out', null); return; }
  pollTimer = setTimeout(async () => {
    try {
      const res = await api('/result/' + encodeURIComponent(job_id));
      if (res.status === 'complete') {
        showCurrentJob(job_id, 'complete', res.cartoon_url);
        loadHistory();
      } else if (res.status === 'error') {
        showCurrentJob(job_id, 'error: ' + (res.error_message || 'unknown'), null);
      } else {
        showCurrentJob(job_id, res.status || 'pending', null);
        pollResult(job_id, attempt + 1);
      }
    } catch(e) {
      showCurrentJob(job_id, 'poll error: ' + e.message, null);
    }
  }, POLL_MS);
}

// =========================================================================
// Gallery
// =========================================================================
function stopGalleryRefresh() {
  if (galleryTimer) { clearTimeout(galleryTimer); galleryTimer = null; }
}

async function loadHistory() {
  if (!auth.currentUser) return;
  setGalleryStatus('Loading…');
  try {
    const res   = await api('/history');
    const items = res.items || [];
    renderGallery(items);
    setGalleryStatus(items.length ? '' : 'No cartoons yet — create one!');
    // Auto-refresh while any job is still pending
    stopGalleryRefresh();
    const pending = items.some(it => it.status === 'submitted' || it.status === 'processing');
    if (pending) galleryTimer = setTimeout(loadHistory, GALLERY_REFRESH_MS);
  } catch(e) {
    setGalleryStatus('Error loading history: ' + e.message);
  }
}

const BLANK = "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'/>";

function makeImageWrap(src, label) {
  const wrap = document.createElement('div');
  wrap.className = 'tile-image-wrap';
  const img = document.createElement('img');
  img.alt = label;
  img.src = src || BLANK;
  const lbl = document.createElement('div');
  lbl.className   = 'img-label';
  lbl.textContent = label;
  wrap.appendChild(img);
  wrap.appendChild(lbl);
  return wrap;
}

function renderGallery(items) {
  const g = document.getElementById('gallery');
  g.innerHTML = '';
  items.forEach(it => {
    const tile   = document.createElement('div');
    tile.className = 'tile';

    const imgs = document.createElement('div');
    imgs.className = 'tile-images';
    imgs.appendChild(makeImageWrap(it.original_url, 'Original'));
    imgs.appendChild(makeImageWrap(it.cartoon_url,  'Cartoon'));
    tile.appendChild(imgs);

    const meta = document.createElement('div');
    meta.className = 'meta';
    const styleTag  = document.createElement('span');
    styleTag.className   = 'style-tag';
    styleTag.textContent = (it.style || '').replace(/_/g, ' ');
    const statusTag = document.createElement('span');
    statusTag.className   = 'status-tag ' + (it.status || '');
    statusTag.textContent = it.status || '';
    meta.appendChild(styleTag);
    meta.appendChild(statusTag);
    tile.appendChild(meta);

    const footer = document.createElement('div');
    footer.style.cssText = 'padding:0 10px 10px 10px; display:flex; gap:6px;';
    if (it.cartoon_url) {
      const dl = document.createElement('a');
      dl.href     = it.cartoon_url;
      dl.download = it.job_id + '.png';
      dl.textContent = 'Download';
      dl.style.cssText = 'font-size:12px; color:#60a5fa; text-decoration:none;';
      footer.appendChild(dl);
    }
    const del = document.createElement('button');
    del.className   = 'delete';
    del.style.cssText = 'padding:4px 8px; font-size:11px; margin-left:auto;';
    del.textContent = 'Delete';
    del.addEventListener('click', () => deleteJob(it.job_id));
    footer.appendChild(del);
    tile.appendChild(footer);

    g.appendChild(tile);
  });
}

async function deleteJob(job_id) {
  if (!confirm('Delete this cartoon?')) return;
  setBusy(true);
  try {
    await api('/history/' + encodeURIComponent(job_id), 'DELETE');
    loadHistory();
  } catch(e) {
    setGalleryStatus('Delete error: ' + e.message);
  } finally {
    setBusy(false);
  }
}

document.getElementById('btnRefresh').addEventListener('click', loadHistory);
</script>

</body>
</html>
